# RemPres ERP — copy to .env.local and fill in (never commit .env.local)
# Supabase: Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci_example_replace_with_anon_public_key

# Server-only. Never use NEXT_PUBLIC_ prefix. Only for getSupabaseAdminClient (users, etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci_example_replace_with_service_role_secret

# Canonical app URL: dev default below; in Vercel set to https://your-domain.com or .vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: marketing site
# NEXT_PUBLIC_MARKETING_URL=https://rempres.com
